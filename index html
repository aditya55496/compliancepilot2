			if (modal) {
				modal.classList.add('is-open');
				modal.setAttribute('aria-hidden', 'false');
			}
		}
		function closeModal() {
			if (modal) {
				modal.classList.remove('is-open');
				modal.setAttribute('aria-hidden', 'true');
			}
		}

		var triggers = document.querySelectorAll('[data-open-waitlist]');
		for (var i = 0; i < triggers.length; i++) {
			triggers[i].addEventListener('click', openModal);
		}
		if (closeBtn) closeBtn.addEventListener('click', closeModal);
		if (modal) {
			modal.addEventListener('click', function (e) {
				if (e.target === modal) closeModal();
			});
		}
		document.addEventListener('keydown', function (e) {
			if (e.key === 'Escape') closeModal();
		});
		if (form) {
			form.addEventListener('submit', function (e) {
				e.preventDefault();
				form.style.display = 'none';
				if (thanks) thanks.style.display = 'flex';
			});
		}

		// Live hero particle-network graphics
		var canvas = document.getElementById('cp-hero-canvas');
		if (canvas && canvas.getContext) {
			var ctx = canvas.getContext('2d');
			var particles = [];
			var w = 0, h = 0, dpr = 1;
			var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			function resize() {
				dpr = window.devicePixelRatio || 1;
				w = canvas.clientWidth;
				h = canvas.clientHeight;
				canvas.width = w * dpr;
				canvas.height = h * dpr;
				ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
			}
			function seed() {
				var count = Math.max(26, Math.min(72, Math.floor(w / 16)));
				particles = [];
				for (var i = 0; i < count; i++) {
					particles.push({
						x: Math.random() * w,
						y: Math.random() * h,
						vx: (Math.random() - 0.5) * 0.45,
						vy: (Math.random() - 0.5) * 0.45,
						r: Math.random() * 2 + 1.2
					});
				}
			}
			function draw() {
				ctx.clearRect(0, 0, w, h);
				for (var i = 0; i < particles.length; i++) {
					for (var j = i + 1; j < particles.length; j++) {
						var a = particles[i], b = particles[j];
						var dx = a.x - b.x, dy = a.y - b.y;
						var dist = Math.sqrt(dx * dx + dy * dy);
						if (dist < 130) {
							ctx.beginPath();
							ctx.moveTo(a.x, a.y);
							ctx.lineTo(b.x, b.y);
							ctx.strokeStyle = 'rgba(39,131,222,' + (0.16 * (1 - dist / 130)) + ')';
							ctx.lineWidth = 1;
							ctx.stroke();
						}
					}
				}
				for (var k = 0; k < particles.length; k++) {
					var p = particles[k];
					ctx.beginPath();
					ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
					ctx.fillStyle = 'rgba(39,131,222,0.6)';
					ctx.fill();
				}
			}
			function step() {
				for (var i = 0; i < particles.length; i++) {
					var p = particles[i];
					p.x += p.vx;
					p.y += p.vy;
					if (p.x < 0 || p.x > w) p.vx *= -1;
					if (p.y < 0 || p.y > h) p.vy *= -1;
				}
				draw();
				requestAnimationFrame(step);
			}
			resize();
			seed();
			if (reduce) { draw(); } else { step(); }
			var rt;
			window.addEventListener('resize', function () {
				clearTimeout(rt);
				rt = setTimeout(function () { resize(); seed(); if (reduce) draw(); }, 150);
			});
		}

		// Scroll-reveal animations across the whole site
		var revealEls = document.querySelectorAll('main > section:not(.notion-hero)');
		if ('IntersectionObserver' in window) {
			for (var r = 0; r < revealEls.length; r++) revealEls[r].classList.add('cp-reveal');
			var io = new IntersectionObserver(function (entries) {
				entries.forEach(function (en) {
					if (en.isIntersecting) { en.target.classList.add('is-visible'); io.unobserve(en.target); }
				});
			}, { threshold: 0.12 });
			for (var r2 = 0; r2 < revealEls.length; r2++) io.observe(revealEls[r2]);
		}

		// Sticky nav shadow on scroll
		var nav = document.getElementById('cp-nav');
		if (nav) {
			window.addEventListener('scroll', function () {
				if (window.scrollY > 8) nav.classList.add('is-scrolled');
				else nav.classList.remove('is-scrolled');
			});
		}

		// JS smooth scroll for in-page links (reliable on the live site)
		var navLinks = document.querySelectorAll('a[href^="#"]:not([data-open-waitlist])');
		for (var n = 0; n < navLinks.length; n++) {
			navLinks[n].addEventListener('click', function (e) {
				var id = this.getAttribute('href');
				if (id && id.length > 1) {
					var target = document.querySelector(id);
					if (target) { e.preventDefault(); target.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
				}
			});
		}

		// Animated count-up stats
		var stats = document.querySelectorAll('.cp-num[data-to]');
		if (stats.length && 'IntersectionObserver' in window) {
			var sObs = new IntersectionObserver(function (entries) {
				entries.forEach(function (en) {
					if (!en.isIntersecting) return;
					var el = en.target;
					sObs.unobserve(el);
					var to = parseFloat(el.getAttribute('data-to'));
					var suffix = el.getAttribute('data-suffix') || '';
					var dur = 1400, t0 = null;
					function tickN(ts) {
						if (!t0) t0 = ts;
						var p = Math.min(1, (ts - t0) / dur);
						var eased = 0.5 - Math.cos(Math.PI * p) / 2;
						el.textContent = Math.floor(to * eased) + suffix;
						if (p < 1) requestAnimationFrame(tickN);
						else el.textContent = to + suffix;
					}
					requestAnimationFrame(tickN);
				});
			}, { threshold: 0.4 });
			for (var s = 0; s < stats.length; s++) sObs.observe(stats[s]);
		}
	})();
</script>
